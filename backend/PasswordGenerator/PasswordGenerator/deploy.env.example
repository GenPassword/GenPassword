# Скопировать в переменные окружения на сервере (systemd, Docker, IIS и т.д.)
# В git реальные значения НЕ хранить.
#
# ASP.NET Core: двойное подчёркивание = вложенный ключ в appsettings
# Jwt:Key  ->  Jwt__Key

ASPNETCORE_ENVIRONMENT=Production

# Обязательно для JWT (логин + сохранение пресетов). Минимум 32 символа.
Jwt__Key=ЗАМЕНИТЕ_НА_ДЛИННЫЙ_СЕКРЕТ_МИНИМУМ_32_СИМВОЛА

# Опционально, если отличаются от appsettings.json
# Jwt__Issuer=PasswordGenerator
# Jwt__Audience=PasswordGeneratorUsers

# PostgreSQL
ConnectionStrings__DefaultConnection=Host=...;Port=5432;Database=...;Username=...;Password=...

# Шифрование сохранённых паролей (если используется)
ENCRYPTION_KEY=ЗАМЕНИТЕ_НА_СЕКРЕТ

# За nginx / reverse proxy
# ReverseProxy__UseForwardedHeaders=true
